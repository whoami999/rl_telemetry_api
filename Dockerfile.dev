# Development Dockerfile with hot-reloading
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm install

# Copy source code
COPY . .

# Expose port 3000
EXPOSE 3000

# Set environment variable
ENV NODE_ENV=development
ENV PORT=3000

# Start with nodemon for hot-reloading
CMD ["npm", "run", "dev"]
